# Receipts — env. Copy to .env.local and fill after the Phase-0 sandbox setup (see HUMAN_SETUP.md).
# NEVER commit .env.local (it's gitignored).

# --- Slack app (from api.slack.com/apps → your app) ---
SLACK_BOT_TOKEN=xoxb-...            # Bot User OAuth Token (OAuth & Permissions)
SLACK_APP_TOKEN=xapp-...           # App-Level Token w/ connections:write (for Socket Mode, dev)
SLACK_SIGNING_SECRET=...           # Basic Information → Signing Secret

# --- The summoner's USER token — the reliable path for permission-scoped RTS search ---
# OAuth & Permissions → User Token Scopes: search:read.public, search:read.private
SLACK_USER_TOKEN=xoxp-...

# --- Anthropic (ranking / repeat-detection / formatting) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Spike config (the seeded go/no-go scenario — see HUMAN_SETUP.md §Seed) ---
SEED_QUERY=Node 18                 # the rare distinctive keyword for the seeded prior decision
SEED_EXPECT_TEXT=dropping Node 18  # a phrase that MUST appear in the returned prior decision
SEED_PRIVATE_QUERY=security audit  # a keyword that lives ONLY in a channel the summoner is NOT in
